# Source files - not needed in production
src/**
**/*.ts
tsconfig.json
biome.json

# Development files
.vscode/**
.github/**
.gitignore

# Test files
**/*.test.js
**/*.spec.js
vitest.config.*

# Build artifacts not needed
**/*.map

# Node modules we don't need (keep only runtime dependencies)
node_modules/**/@types/**
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/*.md
node_modules/**/LICENSE*
node_modules/**/license*
node_modules/**/*.ts
node_modules/**/.github/**

# Other
*.vsix
.git/**
